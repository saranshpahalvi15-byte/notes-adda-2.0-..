rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         ('email' in request.auth.token && (request.auth.token.email == "saransh1860@gmail.com" || request.auth.token.email == "admin@vidyanotes.com" || request.auth.token.email == "masteradmin@vidyanotes.com")));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.id is string && data.id.size() > 0 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidNote(data) {
      return data.title is string && data.price is number;
    }

    function isValidAudioNote(data) {
      return data.title is string && data.audioUrl is string;
    }

    function isValidAudioNoteCreate(data) {
      return data.title is string && data.audioUrl is string;
    }

    function isValidBundle(data) {
      return data.title is string && data.price is number;
    }

    function isValidReview(data) {
      return data.userId is string && data.rating is number;
    }

    function isValidOrder(data) {
      return data.userId is string && data.status is string;
    }

    function isValidCoupon(data) {
      return data.code is string && data.discountPercent is number;
    }

    function isValidQuiz(data) {
      return data.noteId is string && data.title is string && data.questions is list;
    }

    function isValidQuizSubmission(data) {
      return data.userId is string && data.quizId is string && data.score is number && data.total is number;
    }

    function isValidGiveaway(data) {
      return data.noteId is string && data.title is string && data.endTime is string && data.isActive is bool;
    }

    function isValidGiveawayEntry(data) {
      return data.giveawayId is string && data.userId is string && data.userName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if isAdmin();
    }

    match /bundles/{bundleId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if isAdmin();
    }

    match /mindMaps/{mindMapId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if isAdmin();
    }

    match /mockTests/{mockTestId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audioNotes/{audioNoteId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if isAdmin() && isValidQuiz(request.resource.data);
      allow update: if isAdmin() && isValidQuiz(request.resource.data);
      allow delete: if isAdmin();
    }

    match /quizSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidQuizSubmission(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /giveaways/{giveawayId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGiveaway(request.resource.data);
      allow update: if isAdmin() && isValidGiveaway(request.resource.data);
      allow delete: if isAdmin();
    }

    match /giveawayEntries/{entryId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidGiveawayEntry(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
