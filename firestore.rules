rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         ('email' in request.auth.token && (request.auth.token.email == "saransh1860@gmail.com" || request.auth.token.email == "admin@vidyanotes.com" || request.auth.token.email == "masteradmin@vidyanotes.com")));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.id is string && data.id.size() > 0 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidNote(data) {
      return data.title is string && data.price is number;
    }

    function isValidAudioNote(data) {
      return data.title is string && data.audioUrl is string;
    }

    function isValidAudioNoteCreate(data) {
      return data.title is string && data.audioUrl is string;
    }

    function isValidBundle(data) {
      return data.title is string && data.price is number;
    }

    function isValidReview(data) {
      return data.userId is string && data.rating is number;
    }

    function isValidOrder(data) {
      return data.userId is string && data.status is string;
    }

    function isValidCoupon(data) {
      return data.code is string && data.discountPercent is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow create: if isValidNote(request.resource.data);
      allow update: if isValidNote(request.resource.data) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if true;
    }

    match /bundles/{bundleId} {
      allow read: if true;
      allow create: if isValidBundle(request.resource.data);
      allow update: if isValidBundle(request.resource.data) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if true;
    }

    match /mindMaps/{mindMapId} {
      allow read: if true;
      allow create: if isValidNote(request.resource.data);
      allow update: if isValidNote(request.resource.data) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if true;
    }

    match /mockTests/{mockTestId} {
      allow read: if true;
      allow create: if isValidNote(request.resource.data);
      allow update: if isValidNote(request.resource.data) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update: if isValidReview(request.resource.data);
      allow delete: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidOrder(request.resource.data);
      allow update: if isValidOrder(request.resource.data);
      allow delete: if true;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isValidCoupon(request.resource.data);
      allow update: if isValidCoupon(request.resource.data);
      allow delete: if true;
    }

    match /audioNotes/{audioNoteId} {
      allow read: if true;
      allow create: if isValidAudioNoteCreate(request.resource.data);
      allow update: if isValidAudioNote(request.resource.data);
      allow delete: if true;
    }
  }
}
